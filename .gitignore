# Build artifacts
dist/
*.tsbuildinfo

# Dependencies
node_modules/

# Lockfiles we don't commit (we use pnpm)
package-lock.json
yarn.lock

# Test artifacts
coverage/
.vitest-cache/

# Environment / secrets — NEVER commit
.env
.env.*
!.env.example

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Runtime / ephemeral state (in consumer projects; ignored here too for safety)
.rea/audit.jsonl
.rea/audit-*.jsonl
.rea/HALT
.rea/metrics.jsonl
.rea/serve.pid
.rea/serve.state.json
.rea/fingerprints.json
.rea/fingerprints.json.bak.*
.rea/last-review.json
.rea/review-parity.json
.rea/parity-dataset/
.rea/policy.yaml.bak-*
.rea/.delegation-advisory/
.claude/worktrees/
.claude/scheduled_tasks.lock

# Scratch space
.scratch/
.tmp/
*.log

# Editor backups (e.g. walker.ts.bak from sed -i'.bak' invocations)
*.bak

# === rea managed — do not edit between markers ===
.rea/audit.jsonl
.rea/audit-*.jsonl
.rea/HALT
.rea/metrics.jsonl
.rea/serve.pid
.rea/serve.state.json
.rea/fingerprints.json
.rea/last-review.json
.rea/review-parity.json
.rea/parity-dataset/
.rea/*.tmp
.rea/*.tmp.*
.rea/install-manifest.json.bak
.rea/install-manifest.json.tmp
.gitignore.rea-tmp-*
.rea.lock
# === end rea managed ===
